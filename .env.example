# Energex environment configuration
# Copy this file to .env and fill in real values. The live .env is gitignored —
# NEVER commit real secrets. All values below are placeholders.

# =============================================================================
# ArcticDB-on-MinIO storage (the bitemporal store of record)
# =============================================================================
# Read by energex.core.config.ArcticDBConfig and the Dagster ArcticDBResource.

# MinIO endpoint as host:port. Local dev: localhost:9000.
# Inside the compose network, containers reach MinIO at the service name: minio:9000.
MINIO_ENDPOINT=localhost:9000

# Scoped ArcticDB service-account credentials the app authenticates with
# (NOT the MinIO root user). For local `dagster dev` set these directly to the
# scoped account created by minio-init (defaults below: energex-arctic / ...-secret).
MINIO_ACCESS_KEY=energex-arctic
MINIO_SECRET_KEY=change-me-arctic-secret

# ArcticDB bucket and TLS toggle.
ARCTIC_BUCKET=arctic
ARCTIC_SECURE=false

# Optional: full ArcticDB connection URI used by storage.read_curve() when called
# outside the Dagster resource (embeds the S3 secret — keep it out of logs).
# ENERGEX_ARCTIC_URI=s3://localhost:arctic?access=energex-arctic&secret=change-me-arctic-secret&port=9000&use_virtual_addressing=false

# =============================================================================
# MinIO provisioning (docker-compose only)
# =============================================================================
# minio-init uses the root account to create the scoped arctic-rw service account.

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-root

# Scoped service account minio-init creates (and that the Dagster containers then
# pass through as MINIO_ACCESS_KEY / MINIO_SECRET_KEY). Keep in sync with the values above.
ARCTIC_ACCESS_KEY=energex-arctic
ARCTIC_SECRET_KEY=change-me-arctic-secret

# =============================================================================
# Source connector credentials
# =============================================================================

# EIA v2 open-data API key (free): https://www.eia.gov/opendata/register.php
EIA_API_KEY=your-eia-api-key-here

# FRED (St. Louis Fed) API key (free): https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=your-fred-api-key-here

# NOAA token — optional. The nClimDiv degree-day connector reads public flat files
# and needs no token; this is reserved for the keyed NOAA CDO API.
# NOAA_TOKEN=your-noaa-cdo-token-here

# ERCOT (reserved — connector not yet wired). The ERCOT public API needs BOTH an
# Azure APIM subscription key AND OAuth (ROPC) username/password.
# ERCOT_USERNAME=your-ercot-username
# ERCOT_PASSWORD=your-ercot-password
# ERCOT_SUBSCRIPTION_KEY=your-ercot-subscription-key

# =============================================================================
# Dagster (docker-compose only)
# =============================================================================
# Postgres backing the Dagster instance (run/event/schedule storage).

DAGSTER_PG_USERNAME=dagster
DAGSTER_PG_PASSWORD=change-me-dagster-pg
DAGSTER_PG_DB=dagster

# =============================================================================
# Neo4j entity graph (optional; runs under the `full` compose profile)
# =============================================================================
# Read by energex.core.config.Neo4jConfig (app side).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j

# Compose-only: neo4j container auth, in user/password form.
NEO4J_AUTH=neo4j/change-me-neo4j

# =============================================================================
# LLM provider (reserved for the S3 agent; not required to run the platform)
# =============================================================================

# Which provider to use by default: openai, anthropic, or ollama.
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=gemma3:4b

# OpenAI / Anthropic API keys (only the active provider's key is used).
# OPENAI_API_KEY=sk-your-openai-api-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Local Ollama. From a container use http://host.docker.internal:11434.
OLLAMA_BASE_URL=http://localhost:11434

# LLM rate limit and response cache TTL (seconds).
LLM_REQUESTS_PER_MINUTE=10
LLM_CACHE_TTL_SECONDS=3600

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
# Path to a log file (leave unset for console-only logging).
# LOG_FILE=energex.log
LOG_ENABLE_CONSOLE=true

# =============================================================================
# Legacy service (the compose `energex` FastAPI container)
# =============================================================================
# Path to the legacy DuckDB read-path database inside the container.
ENERGEX_DB_PATH=/data/energy.db
# Container timezone and the legacy ingest cron cadence.
TZ=America/Chicago
ENERGEX_INGEST_CRON=*/5 * * * *

# Legacy news sources for the optional sentiment analyzer (reserved).
# NEWS_API_KEY=your-newsapi-key-here
# ALPHA_VANTAGE_KEY=your-alpha-vantage-key-here
